---
import type { CollectionEntry } from 'astro:content';
interface Props { project: CollectionEntry<'projects'>; href: string; locale?: 'zh' | 'en'; headingLevel?: 2 | 3; }
const { project, href, locale = 'zh', headingLevel = 2 } = Astro.props;
const Heading = `h${headingLevel}` as 'h2' | 'h3';
---
<article class="card">
  <img src={project.data.cover} alt={project.data.title + (locale === 'zh' ? '项目封面' : ' project cover')} width="1600" height="900" loading="lazy" decoding="async" />
  <div class="card-body">
    <p class="eyebrow">{project.data.status}</p>
    <Heading><a href={href}>{project.data.title}</a></Heading>
    <p>{project.data.summary}</p>
    <ul class="tags" aria-label={locale === 'zh' ? '使用技术' : 'Technologies'}>
      {project.data.technologies.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</article>
